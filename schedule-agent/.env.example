# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Your Gmail address (used as sender and recipient for proposals/reminders)
YOUR_EMAIL=you@gmail.com

# Google OAuth credentials file path (downloaded from Google Cloud Console)
GOOGLE_CREDENTIALS_FILE=credentials.json

# Google OAuth token file (auto-generated on first auth run)
GOOGLE_TOKEN_FILE=token.json

# Flask approval server port
APPROVAL_SERVER_PORT=5555
